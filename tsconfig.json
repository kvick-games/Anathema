{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "rootDir": "src",
    "outDir": "dist",
    "strict": false,
    "skipLibCheck": true,
    "sourceMap": false,
    "declaration": false,
    "noEmitOnError": false
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
